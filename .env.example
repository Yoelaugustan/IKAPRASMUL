# Copy this file to `.env` (same folder as docker-compose.yml) and fill in real
# values. docker compose reads `.env` automatically. Never commit the real .env.

# --- Database --------------------------------------------------------------
# Password for the bundled PostgreSQL container (user is always "postgres").
POSTGRES_PASSWORD=change_me

# --- Email (Brevo SMTP) ----------------------------------------------------
SMTP_USERNAME=your_brevo_smtp_login
SMTP_PASSWORD=your_brevo_smtp_password

# --- URLs ------------------------------------------------------------------
# Public origin of the frontend — used for backend CORS, e.g. https://ikaprasmul.com
FRONTEND_ORIGIN=http://localhost:3000

# Public URL the BROWSER uses to reach the backend (inlined into the frontend
# build). Subdomain style: https://api.ikaprasmul.com — or path style via the
# host nginx: https://ikaprasmul.com/api.
NEXT_PUBLIC_API_URL=http://localhost:5080
