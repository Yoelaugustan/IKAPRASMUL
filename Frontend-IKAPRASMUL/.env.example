# Backend API URL — used server-side by Next.js (not exposed to browser)
# In production: internal URL if BE and FE are on the same server, e.g. http://localhost:5080
# In production: public URL if BE is on a separate server, e.g. https://api.ikaprasmul.com
API_URL=http://localhost:5080

# Backend API URL — used client-side (sent to browser, must be publicly reachable)
# In production: the public HTTPS URL of the backend, e.g. https://api.ikaprasmul.com
NEXT_PUBLIC_API_URL=http://localhost:5080
